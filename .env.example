# Nexus Agentic OS - Environment Configuration Example
# Copy this file to .env and fill in your API keys

# =============================================================================
# Tavily API Keys (Required for web search functionality)
# =============================================================================
# Get your API key at: https://tavily.com
#
# Option 1: Single API Key
# TAVILY_API_KEY=tvly-your-api-key-here
#
# Option 2: Multiple API Keys (comma-separated) for rotation
# This enables automatic key rotation when rate limits are hit
TAVILY_API_KEYS=tvly-your-first-key-here,tvly-your-second-key-here

# =============================================================================
# Optional: System Proxy (for HTTP requests)
# =============================================================================
# HTTP_PROXY=http://127.0.0.1:8080
# HTTPS_PROXY=http://127.0.0.1:8080
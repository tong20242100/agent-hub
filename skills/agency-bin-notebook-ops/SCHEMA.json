{
  "name": "agency-bin-notebook-ops",
  "version": "2.1.0",
  "protocol": "1.0",
  "description": "NotebookLM 自动化工具 - 认证、查询、重置",
  "tools": {
    "notebook_auth": {
      "description": "启动 Google 登录认证流程，保存 NotebookLM 登录状态。",
      "command": "bin/notebook-ops auth",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    "notebook_query": {
      "description": "查询 NotebookLM 笔记本内容。",
      "command": "bin/notebook-ops query --url {notebook_url} --q {question}",
      "parameters": {
        "type": "object",
        "properties": {
          "notebook_url": {
            "type": "string",
            "description": "NotebookLM 笔记本 URL"
          },
          "question": {
            "type": "string",
            "description": "问题内容"
          }
        },
        "required": [
          "notebook_url",
          "question"
        ]
      }
    },
    "notebook_clean": {
      "description": "清除 NotebookLM 认证状态，重新登录时使用。",
      "command": "bin/notebook-ops clean",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    }
  },
  "ai_hints": {
    "when_to_use": "用户需要操作 Google NotebookLM 笔记本时：登录认证、查询笔记内容、重置认证状态。例如'帮我查一下这个 NotebookLM 笔记本'、'重新登录 NotebookLM'",
    "examples": [
      {
        "action": "首次使用或登录失效",
        "command": "notebook_auth"
      },
      {
        "action": "查询笔记内容",
        "command": "notebook_query(notebook_url='https://notebooklm.google.com/notebook/xxx', question='总结这个笔记本的核心内容')"
      },
      {
        "action": "重置认证",
        "command": "notebook_clean"
      }
    ],
    "avoid": "不需要操作 NotebookLM 时不要用；普通 Google Docs 用其他方式",
    "self_check": [
      "你能通过原生能力或代码执行完成此任务吗？能 -> 优先用原生的",
      "需要调用此特定工具提供的物理环境或 API？是 -> 调此工具"
    ]
  },
  "requires": {
    "bins": [
      "notebook-ops"
    ]
  },
  "source": {
    "type": "local_script"
  },
  "dependencies": [
    {
      "name": "patchright",
      "type": "pip"
    },
    {
      "name": "playwright-stealth",
      "type": "pip"
    }
  ],
  "type": "bin-wrapper",
  "bin_path": "bin/notebook-ops"
}
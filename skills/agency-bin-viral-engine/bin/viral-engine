#!/usr/bin/env python3

# --- Physical Path Hardening (Nexus 2.0) ---
import os
_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
if "/skills/" in _SCRIPT_DIR:
    WORKSPACE_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, "../../.."))
else:
    WORKSPACE_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, ".."))

import sys
import os
import datetime

# ==============================================================================
# 🚀 Viral Engine v3.1 - Agentic OS 爆款内容自动分发器
# 作用: 封装 processor_v3.py 逻辑。自动将生成的爆款 Thread 存档至 knowledge/distribution/。
# ==============================================================================

DISTRIBUTION_DIR = '/Users/tong/agent-hub/knowledge/distribution'
PROCESSOR_PATH = '/Users/tong/agent-hub/scripts/viral_engine/processor_v3.py'

if len(sys.argv) < 2:
    print("Usage: viral-engine <path_to_report>")
    sys.exit(1)

target_report = sys.argv[1]
if not os.path.exists(target_report):
    print(f"❌ Error: Report not found at {target_report}")
    sys.exit(1)

# 1. 启动内容转换
print(f"🔥 [Viral-Engine] 正在启动内容裂变引擎: {target_report}")
try:
    # 调用底层 processor_v3.py 获取结果
    import subprocess
    result = subprocess.check_output(['python3', PROCESSOR_PATH, target_report]).decode('utf-8')
    
    # 2. 自动生成存档文件名
    report_basename = os.path.splitext(os.path.basename(target_report))[0]
    timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M")
    archive_filename = f"Viral_Thread_{report_basename}_{timestamp}.md"
    archive_path = os.path.join(DISTRIBUTION_DIR, archive_filename)
    
    # 3. 物理存档
    os.makedirs(DISTRIBUTION_DIR, exist_ok=True)
    with open(archive_path, 'w', encoding='utf-8') as f:
        f.write(f"--- SOURCE: {target_report} ---\n\n")
        f.write(result)
    
    # 4. 终端输出与回响
    print(result)
    print("-" * 40)
    print(f"✅ [Auto-Archive] 爆款内容已自动存档至: {archive_path}")

except Exception as e:
    print(f"❌ Viral Engine Execution Failed: {e}")
    sys.exit(1)

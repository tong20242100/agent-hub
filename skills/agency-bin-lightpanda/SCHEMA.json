{
  "name": "agency-bin-lightpanda",
  "version": "1.0.0",
  "protocol": "1.0",
  "description": "Lightpanda 无头浏览器。高性能 Zig 引擎，支持 JS 渲染页面的快速抓取与分析（fetch/serve/mcp 模式）。",
  "tools": {
    "fetch": {
      "description": "抓取网页内容。支持 html/markdown/semantic_tree 输出。例如: fetch(url='https://example.com', dump='markdown')",
      "command": "bin/lightpanda fetch --dump {dump} --log_level warn {url}",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "目标 URL"
          },
          "dump": {
            "type": "string",
            "description": "输出格式: html, markdown, semantic_tree, semantic_tree_text",
            "default": "markdown",
            "enum": [
              "html",
              "markdown",
              "semantic_tree",
              "semantic_tree_text"
            ]
          },
          "strip_mode": {
            "type": "string",
            "description": "移除内容: js, css, ui, full (逗号分隔)"
          },
          "obey_robots": {
            "type": "boolean",
            "description": "遵守 robots.txt",
            "default": false
          }
        },
        "required": [
          "url"
        ]
      }
    },
    "serve": {
      "description": "启动 CDP 服务器。供 Puppeteer/Playwright 连接。例如: serve(host='127.0.0.1', port=9222)",
      "command": "bin/lightpanda serve --host {host} --port {port} --log_level warn",
      "parameters": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string",
            "description": "监听地址",
            "default": "127.0.0.1"
          },
          "port": {
            "type": "integer",
            "description": "监听端口",
            "default": 9222
          }
        },
        "required": []
      }
    },
    "mcp": {
      "description": "启动 MCP 服务器 (stdio 模式)。供 AI Agent 直接调用。",
      "command": "bin/lightpanda mcp",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    }
  },
  "ai_hints": {
    "intent": "高性能无头浏览器，用于抓取 JS 渲染页面",
    "self_check": [
      "环境是否支持原生 JS 渲染？支持 -> 优先用原生的",
      "目标页面是否为简单静态页面？是 -> 优先用 scrape_url",
      "是否需要深度分析页面语义结构（semantic_tree）？是 -> 调此工具"
    ],
    "when_to_use": "用于抓取/分析需要 JS 渲染的 SPA 应用页面，在缺乏原生渲染能力时。",
    "avoid": "静态页面用 scrape_url；交互任务（点击/输入）用 chrome-devtools；绕过反爬用 stealth_get",
    "examples": [
      {"url": "https://nextjs.org/docs", "dump": "markdown"},
      {"url": "https://react.dev/reference", "dump": "semantic_tree"},
      {"url": "https://docs.angular.dev/guide", "dump": "markdown"}
    ]
  },
  "source": {
    "type": "github_release",
    "repo": "lightpanda-io/browser",
    "asset_pattern": "lightpanda-macos-arm64",
    "installed_version": "nightly-20260315",
    "installed_at": "2026-03-16",
    "download_url": "https://github.com/lightpanda-io/browser/releases"
  },
  "requires": {
    "bins": [
      "python3",
      "lightpanda"
    ],
    "env": []
  }
}
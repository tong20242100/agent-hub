{
  "name": "agency-bin-chrome-devtools",
  "version": "0.20.1",
  "protocol": "nexus-2.0",
  "description": "Chrome DevTools MCP - Google 官方 MCP 服务器，让 AI Agent 控制和检查 Chrome 浏览器",
  "tools": {
    "click": {
      "description": "点击页面元素。例如: click(selector='button#submit')",
      "command": "mcp://chrome-devtools/click",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": {
            "type": "string",
            "description": "CSS 选择器"
          },
          "element": {
            "type": "string",
            "description": "元素描述（供 AI 识别）"
          }
        },
        "required": ["selector"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要在浏览器中点击按钮、链接或其他可交互元素时",
        "examples": [
          {"selector": "button#submit", "element": "提交按钮"},
          {"selector": "a.more-link", "element": "查看更多链接"},
          {"selector": "[data-testid='accept-cookies']", "element": "Cookie 同意按钮"}
        ],
        "avoid": "静态页面抓取不需要交互，用 scrape_url 更快"
      }
    },
    "fill": {
      "description": "填充输入框。例如: fill(selector='input[name=\"q\"]', value='hello')",
      "command": "mcp://chrome-devtools/fill",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": {
            "type": "string",
            "description": "CSS 选择器"
          },
          "value": {
            "type": "string",
            "description": "要填充的值"
          }
        },
        "required": ["selector", "value"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要在浏览器中填充单个输入框时",
        "examples": [
          {"selector": "input[name='q']", "value": "AI agents"},
          {"selector": "#username", "value": "user@example.com"}
        ],
        "avoid": "多个字段用 fill_form 一次性填充更高效"
      }
    },
    "type_text": {
      "description": "输入文本。例如: type_text(text='hello world')",
      "command": "mcp://chrome-devtools/type_text",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "要输入的文本"
          }
        },
        "required": ["text"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要在当前焦点元素中输入文本时（模拟键盘输入）",
        "examples": [
          {"text": "Hello, world!"},
          {"text": "搜索关键词"}
        ],
        "avoid": "如果知道具体输入框选择器，用 fill 更精确"
      }
    },
    "navigate_page": {
      "description": "导航到 URL。例如: navigate_page(url='https://example.com')",
      "command": "mcp://chrome-devtools/navigate_page",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "目标 URL"
          }
        },
        "required": ["url"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要打开新网页或跳转到特定 URL 时",
        "examples": [
          {"url": "https://github.com"},
          {"url": "https://example.com/product/123"}
        ],
        "avoid": "如果只是抓取静态内容，用 scrape_url 不需要启动浏览器"
      }
    },
    "list_pages": {
      "description": "列出所有打开的页面/标签页",
      "command": "mcp://chrome-devtools/list_pages",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "ai_hints": {
        "when_to_use": "当用户需要查看当前浏览器中打开了哪些标签页时",
        "examples": [{}],
        "avoid": "单页面操作不需要调用"
      }
    },
    "select_page": {
      "description": "选择/切换到指定页面。例如: select_page(pageId='abc123')",
      "command": "mcp://chrome-devtools/select_page",
      "parameters": {
        "type": "object",
        "properties": {
          "pageId": {
            "type": "string",
            "description": "页面 ID"
          }
        },
        "required": ["pageId"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要在多个标签页之间切换时",
        "examples": [
          {"pageId": "page-123"}
        ],
        "avoid": "先用 list_pages 获取 pageId"
      }
    },
    "new_page": {
      "description": "打开新页面。例如: new_page(url='https://example.com')",
      "command": "mcp://chrome-devtools/new_page",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "初始 URL（可选）"
          }
        },
        "required": []
      },
      "ai_hints": {
        "when_to_use": "当用户需要打开新标签页，同时保持当前页面不关闭时",
        "examples": [
          {"url": "https://example.com"},
          {}
        ],
        "avoid": "如果只是导航，用 navigate_page 更简单"
      }
    },
    "close_page": {
      "description": "关闭页面。例如: close_page(pageId='abc123')",
      "command": "mcp://chrome-devtools/close_page",
      "parameters": {
        "type": "object",
        "properties": {
          "pageId": {
            "type": "string",
            "description": "页面 ID（可选，默认关闭当前页面）"
          }
        },
        "required": []
      },
      "ai_hints": {
        "when_to_use": "当用户需要关闭特定标签页时",
        "examples": [
          {"pageId": "page-456"},
          {}
        ],
        "avoid": "关闭最后一个页面会结束会话"
      }
    },
    "take_screenshot": {
      "description": "截图当前页面。例如: take_screenshot()",
      "command": "mcp://chrome-devtools/take_screenshot",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": {
            "type": "string",
            "description": "截图特定元素（可选）"
          }
        },
        "required": []
      },
      "ai_hints": {
        "when_to_use": "当用户需要可视化当前页面状态，或调试页面渲染问题时",
        "examples": [
          {},
          {"selector": ".product-card"}
        ],
        "avoid": "如果只需要文本内容，用 take_snapshot 更高效"
      }
    },
    "take_snapshot": {
      "description": "获取页面可访问性快照（语义化结构）",
      "command": "mcp://chrome-devtools/take_snapshot",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "ai_hints": {
        "when_to_use": "当用户需要了解页面结构、找到可交互元素时",
        "examples": [{}],
        "avoid": "这是探索页面的第一步，先调用这个再决定后续操作"
      }
    },
    "evaluate_script": {
      "description": "在页面中执行 JavaScript。例如: evaluate_script(script='document.title')",
      "command": "mcp://chrome-devtools/evaluate_script",
      "parameters": {
        "type": "object",
        "properties": {
          "script": {
            "type": "string",
            "description": "JavaScript 代码"
          }
        },
        "required": ["script"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要获取动态生成的数据、执行复杂页面操作时",
        "examples": [
          {"script": "document.title"},
          {"script": "document.querySelector('.price').textContent"},
          {"script": "Array.from(document.querySelectorAll('.item')).map(e => e.textContent)"}
        ],
        "avoid": "简单元素操作用 click/fill 更直观"
      }
    },
    "hover": {
      "description": "悬停在元素上。例如: hover(selector='button#menu')",
      "command": "mcp://chrome-devtools/hover",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": {
            "type": "string",
            "description": "CSS 选择器"
          }
        },
        "required": ["selector"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要触发下拉菜单、工具提示等悬停效果时",
        "examples": [
          {"selector": ".dropdown-toggle"},
          {"selector": "[data-tooltip]"}
        ],
        "avoid": "大多数操作不需要悬停"
      }
    },
    "press_key": {
      "description": "按键。例如: press_key(key='Enter')",
      "command": "mcp://chrome-devtools/press_key",
      "parameters": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "按键名称（如 Enter, Tab, Escape）"
          }
        },
        "required": ["key"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要发送键盘事件，如提交表单、导航等",
        "examples": [
          {"key": "Enter"},
          {"key": "Escape"},
          {"key": "Tab"}
        ],
        "avoid": "表单提交通常用 click 点击提交按钮更可靠"
      }
    },
    "wait_for": {
      "description": "等待条件。例如: wait_for(selector='.loaded')",
      "command": "mcp://chrome-devtools/wait_for",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": {
            "type": "string",
            "description": "等待元素出现"
          },
          "text": {
            "type": "string",
            "description": "等待文本出现"
          },
          "timeout": {
            "type": "number",
            "description": "超时时间（毫秒）"
          }
        },
        "required": []
      },
      "ai_hints": {
        "when_to_use": "当页面需要时间加载内容，用户需要等待特定元素出现时",
        "examples": [
          {"selector": ".results-loaded"},
          {"text": "加载完成"},
          {"selector": "table.data", "timeout": 5000}
        ],
        "avoid": "过度等待会拖慢操作，设置合理的 timeout"
      }
    },
    "performance_start_trace": {
      "description": "开始性能追踪",
      "command": "mcp://chrome-devtools/performance_start_trace",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "ai_hints": {
        "when_to_use": "当用户需要分析页面性能问题时，开始录制性能数据",
        "examples": [{}],
        "avoid": "常规操作不需要性能追踪"
      }
    },
    "performance_stop_trace": {
      "description": "停止性能追踪",
      "command": "mcp://chrome-devtools/performance_stop_trace",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "ai_hints": {
        "when_to_use": "结束性能录制，准备分析数据",
        "examples": [{}],
        "avoid": "必须先调用 performance_start_trace"
      }
    },
    "performance_analyze_insight": {
      "description": "分析性能洞察",
      "command": "mcp://chrome-devtools/performance_analyze_insight",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "ai_hints": {
        "when_to_use": "当用户需要获取性能分析报告和优化建议时",
        "examples": [{}],
        "avoid": "需要先执行性能追踪"
      }
    },
    "list_network_requests": {
      "description": "列出网络请求",
      "command": "mcp://chrome-devtools/list_network_requests",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "ai_hints": {
        "when_to_use": "当用户需要查看页面加载过程中的网络请求，调试 API 调用时",
        "examples": [{}],
        "avoid": "如果知道具体请求 ID，直接用 get_network_request"
      }
    },
    "get_network_request": {
      "description": "获取网络请求详情。例如: get_network_request(requestId='123')",
      "command": "mcp://chrome-devtools/get_network_request",
      "parameters": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string",
            "description": "请求 ID"
          }
        },
        "required": ["requestId"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要查看特定请求的详细信息（请求头、响应体等）",
        "examples": [
          {"requestId": "request-123"}
        ],
        "avoid": "先用 list_network_requests 获取 requestId"
      }
    },
    "list_console_messages": {
      "description": "列出控制台消息",
      "command": "mcp://chrome-devtools/list_console_messages",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "ai_hints": {
        "when_to_use": "当用户需要查看页面的控制台输出，调试 JavaScript 错误时",
        "examples": [{}],
        "avoid": "正常操作不需要查看控制台"
      }
    },
    "get_console_message": {
      "description": "获取控制台消息详情",
      "command": "mcp://chrome-devtools/get_console_message",
      "parameters": {
        "type": "object",
        "properties": {
          "messageId": {
            "type": "string",
            "description": "消息 ID"
          }
        },
        "required": ["messageId"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要查看特定控制台消息的详细信息",
        "examples": [
          {"messageId": "msg-456"}
        ],
        "avoid": "先用 list_console_messages 获取 messageId"
      }
    },
    "lighthouse_audit": {
      "description": "运行 Lighthouse 审计。例如: lighthouse_audit(url='https://example.com')",
      "command": "mcp://chrome-devtools/lighthouse_audit",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "审计 URL"
          },
          "categories": {
            "type": "array",
            "description": "审计类别（performance, accessibility, seo 等）"
          }
        },
        "required": ["url"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要全面评估网页性能、可访问性、SEO 等指标时",
        "examples": [
          {"url": "https://example.com"},
          {"url": "https://example.com", "categories": ["performance", "accessibility"]}
        ],
        "avoid": "审计耗时较长，只在需要完整报告时使用"
      }
    },
    "emulate": {
      "description": "模拟设备。例如: emulate(device='iPhone 13')",
      "command": "mcp://chrome-devtools/emulate",
      "parameters": {
        "type": "object",
        "properties": {
          "device": {
            "type": "string",
            "description": "设备名称"
          }
        },
        "required": ["device"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要测试移动端体验，模拟不同设备时",
        "examples": [
          {"device": "iPhone 13"},
          {"device": "iPad Pro"},
          {"device": "Pixel 5"}
        ],
        "avoid": "桌面端测试不需要模拟设备"
      }
    },
    "resize_page": {
      "description": "调整页面大小。例如: resize_page(width=1280, height=720)",
      "command": "mcp://chrome-devtools/resize_page",
      "parameters": {
        "type": "object",
        "properties": {
          "width": {
            "type": "number",
            "description": "宽度（像素）"
          },
          "height": {
            "type": "number",
            "description": "高度（像素）"
          }
        },
        "required": ["width", "height"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要测试响应式布局，自定义视口大小时",
        "examples": [
          {"width": 1920, "height": 1080},
          {"width": 375, "height": 667}
        ],
        "avoid": "常见设备用 emulate 更方便"
      }
    },
    "fill_form": {
      "description": "填充表单。例如: fill_form(fields=[{'selector': 'input[name]', 'value': 'John'}])",
      "command": "mcp://chrome-devtools/fill_form",
      "parameters": {
        "type": "object",
        "properties": {
          "fields": {
            "type": "array",
            "description": "表单字段数组"
          }
        },
        "required": ["fields"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要一次性填充多个表单字段时",
        "examples": [
          {"fields": [{"selector": "#name", "value": "John"}, {"selector": "#email", "value": "john@example.com"}]}
        ],
        "avoid": "单字段用 fill 更简单"
      }
    },
    "handle_dialog": {
      "description": "处理对话框（alert/confirm/prompt）",
      "command": "mcp://chrome-devtools/handle_dialog",
      "parameters": {
        "type": "object",
        "properties": {
          "accept": {
            "type": "boolean",
            "description": "是否接受对话框"
          },
          "text": {
            "type": "string",
            "description": "输入文本（prompt 时）"
          }
        },
        "required": []
      },
      "ai_hints": {
        "when_to_use": "当页面弹出 alert/confirm/prompt 对话框需要处理时",
        "examples": [
          {"accept": true},
          {"accept": false},
          {"accept": true, "text": "我的回答"}
        ],
        "avoid": "现代网站很少使用原生对话框"
      }
    },
    "drag": {
      "description": "拖拽元素。例如: drag(fromSelector='#item', toSelector='#target')",
      "command": "mcp://chrome-devtools/drag",
      "parameters": {
        "type": "object",
        "properties": {
          "fromSelector": {
            "type": "string",
            "description": "源元素选择器"
          },
          "toSelector": {
            "type": "string",
            "description": "目标元素选择器"
          }
        },
        "required": ["fromSelector", "toSelector"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要执行拖拽操作，如排序、移动文件等",
        "examples": [
          {"fromSelector": ".item-1", "toSelector": ".drop-zone"},
          {"fromSelector": "[draggable='true']", "toSelector": ".folder"}
        ],
        "avoid": "大多数操作不需要拖拽"
      }
    },
    "upload_file": {
      "description": "上传文件。例如: upload_file(selector='input[type=file]', filePath='/path/to/file')",
      "command": "mcp://chrome-devtools/upload_file",
      "parameters": {
        "type": "object",
        "properties": {
          "selector": {
            "type": "string",
            "description": "文件输入框选择器"
          },
          "filePath": {
            "type": "string",
            "description": "文件路径"
          }
        },
        "required": ["selector", "filePath"]
      },
      "ai_hints": {
        "when_to_use": "当用户需要上传文件到网页时",
        "examples": [
          {"selector": "input[type='file']", "filePath": "~/Documents/report.pdf"},
          {"selector": "#avatar-upload", "filePath": "~/Pictures/avatar.png"}
        ],
        "avoid": "确保文件路径存在且可访问"
      }
    },
    "take_memory_snapshot": {
      "description": "获取内存快照",
      "command": "mcp://chrome-devtools/take_memory_snapshot",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "ai_hints": {
        "when_to_use": "当用户需要分析页面内存使用情况，排查内存泄漏时",
        "examples": [{}],
        "avoid": "常规操作不需要内存快照"
      }
    }
  },
  "ai_hints": {
    "when_to_use": "当用户需要在浏览器中进行复杂交互（点击、填表、等待加载、调试）时",
    "examples": [
      {"workflow": "navigate → take_snapshot → click → wait_for → take_screenshot"}
    ],
    "avoid": "静态内容抓取用 scrape_url 或 stealth_get，不需要浏览器交互"
  },
  "source": {
    "type": "npm",
    "package": "chrome-devtools-mcp",
    "repo": "ChromeDevTools/chrome-devtools-mcp",
    "installed_version": "0.20.0",
    "installed_at": "2026-03-17",
    "update_command": "npm update -g chrome-devtools-mcp"
  },
  "requires": {
    "bins": ["npx"],
    "env": []
  }
}

#!/usr/bin/env python3

# --- Physical Path Hardening (Nexus 2.0) ---
import os
_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
if "/skills/" in _SCRIPT_DIR:
    WORKSPACE_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, "../../.."))
else:
    WORKSPACE_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, ".."))

import sys
import json
import subprocess
import os

# ==============================================================================
# 🔌 Agentic OS MCP Server - 跨工具火控适配器 (v6.0 Governor Edition)
# 作用: 遵循 Model Context Protocol，将本地 bin/ 武器暴露给外部 AI 客户端。
# ==============================================================================

MANIFEST_PATH = os.path.join(WORKSPACE_ROOT, "knowledge/tools_manifest.json")
BIN_DIR = os.path.join(WORKSPACE_ROOT, "bin")

# 注入内核神经元与流量调节官
sys.path.append(os.path.join(BIN_DIR, 'kernel'))
try:
    import telemetry, governor
except ImportError:
    telemetry = None
    governor = None

def load_tools():
    if not os.path.exists(MANIFEST_PATH):
        return []
    with open(MANIFEST_PATH, 'r') as f:
        return json.load(f).get('tools', [])

def find_active_run_dir():
    """找到最近活跃的沙盒目录"""
    runs_root = os.path.join(WORKSPACE_ROOT, "workspace")
    if not os.path.exists(runs_root): return None
    dirs = [os.path.join(runs_root, d) for d in os.listdir(runs_root) if os.path.isdir(os.path.join(runs_root, d))]
    if not dirs: return None
    return max(dirs, key=os.path.getmtime)

def handle_request(request):
    """处理 MCP 标准请求 (Tool Call)"""
    method = request.get('method')
    params = request.get('params', {})
    
    if method == "tools/list":
        return {"tools": load_tools()}
        
    if method == "tools/call":
        tool_name = params.get('name')
        args = params.get('arguments', {})
        run_dir = find_active_run_dir()
        
        tool_executable = os.path.join(BIN_DIR, tool_name)
        if os.path.exists(tool_executable):
            def execute_tool():
                # --- 流量调节 (The Governor) ---
                # 只有涉及到外部调用的工具（含有 url, target, 或 arg 参数的）才触发限速
                if governor:
                    target_val = str(args.get('url', args.get('target', args.get('arg1', ''))))
                    governor.wait_for_slot(target_val)

                cmd = [tool_executable]
                for k, v in args.items():
                    if v is None: continue
                    if k.startswith('arg'):
                        cmd.append(str(v))
                    else:
                        cmd.extend([f"--{k}", str(v)])
                return subprocess.check_output(cmd, stderr=subprocess.STDOUT).decode('utf-8')

            try:
                # 使用神经元包装执行逻辑
                if telemetry and run_dir:
                    result = telemetry.wrap_tool_call(run_dir, tool_name, args, execute_tool)
                else:
                    result = execute_tool()
                
                return {"content": [{"type": "text", "text": result}]}
            except subprocess.CalledProcessError as e:
                output = e.output.decode('utf-8')
                return {"isError": True, "content": [{"type": "text", "text": output}]}
            except Exception as e:
                return {"isError": True, "message": str(e)}
        
        return {"isError": True, "message": f"Tool '{tool_name}' not found in bin/"}

def main():
    """使用标准 I/O (stdio) 进行 MCP 通信"""
    for line in sys.stdin:
        try:
            request = json.loads(line)
            response = handle_request(request)
            print(json.dumps({
                "jsonrpc": "2.0",
                "id": request.get('id'),
                "result": response
            }, ensure_ascii=False), flush=True)
        except Exception:
            continue

if __name__ == "__main__":
    main()

{
  "name": "agency-bin-scrape",
  "version": "3.0.0",
  "protocol": "1.0",
  "description": "网页抓取工具 - 静态抓取 + 递归追踪外部链接",
  "tools": {
    "scrape_url": {
      "description": "提取网页内容为 Markdown。支持 --recursive 递归追踪外部链接",
      "command": "bin/scrape {url} {recursive?--recursive} --depth {depth}",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "目标 URL"
          },
          "recursive": {
            "type": "boolean",
            "default": false,
            "description": "是否递归追踪外部链接"
          },
          "depth": {
            "type": "integer",
            "default": 2,
            "description": "递归深度"
          }
        },
        "required": [
          "url"
        ]
      }
    }
  },
  "ai_hints": {
    "triggers": [
      "抓取",
      "scrape",
      "爬取",
      "网页",
      "page",
      "提取",
      "fetch",
      "url"
    ],
    "intent": "快速抓取静态网页内容为 Markdown",
    "self_check": [
      "你有原生抓取/访问 URL 的能力吗？有 -> 优先用自己的，不调此工具",
      "页面是否需要递归追踪外部链接（--recursive）？是 -> 调此工具",
      "如果是动态 JS 页面或有反爬？是 -> 考虑用 lightpanda 或 stealth_get"
    ],
    "when_to_use": "你需要抓取网页内容为 Markdown，且你没有原生能力，或需要递归追踪功能时",
    "avoid": "简单页面且你有原生访问能力时禁用；有反爬保护用 stealth_get；需 JS 渲染用 lightpanda；需交互用 chrome-devtools",
    "examples": [
      {"url": "https://docs.python.org/3/tutorial/index.html"},
      {"url": "https://blog.example.com/article", "recursive": true}
    ],
    "conditions": {
      "use_alternative": {
        "stealth_get": "跳过 Cloudflare/WAF 保护（如知乎/小红书/Medium）",
        "lightpanda": "超快速 JS 渲染抓取",
        "click": "需要点击/填写等复杂交互 (chrome-devtools)"
      }
    }
  },
  "requires": {
    "bins": [
      "python3"
    ],
    "env": []
  },
  "type": "bin-wrapper",
  "bin_path": "bin/scrape",
  "dependencies": [
    {
      "name": "requests",
      "type": "pip",
      "description": "HTTP library",
      "check_command": "pip show requests",
      "update_cmd": "pip install --upgrade requests"
    },
    {
      "name": "beautifulsoup4",
      "type": "pip",
      "description": "HTML parser",
      "check_command": "pip show beautifulsoup4",
      "update_cmd": "pip install --upgrade beautifulsoup4"
    }
  ]
}
#!/usr/bin/env python3

# --- Physical Path Hardening ---
import os
_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
if "/skills/" in _SCRIPT_DIR:
    WORKSPACE_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, "../../.."))
else:
    WORKSPACE_ROOT = os.path.abspath(os.path.join(_SCRIPT_DIR, ".."))

import sys, os, json, requests

# ==============================================================================
# 📢 Notify - IM 消息分发器 (v5.2 Distribution)
# 作用: 将 Agent 的发现通过 Webhook 实时推送到你的飞书/Bark/Telegram。
# ==============================================================================

CONFIG_PATH = os.path.expanduser("~/.openclaw-vault/notify_config.json")

def send_notification(message):
    if not os.path.exists(CONFIG_PATH):
        print("⚠️ 未发现通知配置。消息仅打印在终端：")
        print(f">>> {message}")
        return

    with open(CONFIG_PATH, 'r') as f:
        config = json.load(f)

    # 1. 飞书方案
    if "feishu_url" in config:
        payload = {"msg_type": "text", "content": {"text": message}}
        requests.post(config['feishu_url'], json=payload)
        print("✅ 消息已推送至飞书。")

    # 2. Bark 方案 (iOS 专用)
    if "bark_url" in config:
        url = f"{config['bark_url']}/{message}"
        requests.get(url)
        print("✅ 消息已推送至 Bark (iOS)。")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: notify <message>")
        sys.exit(1)
    
    msg = sys.argv[1]
    send_notification(msg)

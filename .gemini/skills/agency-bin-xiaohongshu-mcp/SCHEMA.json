{
  "name": "agency-bin-xiaohongshu-mcp",
  "version": "2.1.0",
  "protocol": "nexus-2.0",
  "tools": {
    "login": {
      "description": "【安全禁令：扫码唯一性】启动物理浏览器扫码登录。禁止使用账号密码自动填充。登录后必须确保此账号在其他浏览器页签中已退出，严禁多端网页登录。",
      "command": "bin/xhs-login",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    "search": {
      "description": "【频率限制】搜索小红书笔记。单次操作后需随机停顿 5-10 秒，严禁高频并发。",
      "command": "bin/xhs-mcp tool call search_feeds '{\"keyword\":\"{query}\"}'",
      "parameters": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "搜索关键词" }
        },
        "required": ["query"]
      }
    },
    "publish_image": {
      "description": "【安全发布铁律】1.日发布量严禁超过 50 篇；2.图片必须经过 MD5 微调（裁剪或滤镜）；3.文案禁止包含敏感引流词；4.发布动作必须模拟人类作息（凌晨不发帖）。",
      "command": "bin/xhs-mcp tool call publish_content '{\"title\":\"{title}\", \"content\":\"{content}\", \"images\":[\"{image_path}\"]}'",
      "parameters": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "maxLength": 20, "description": "标题限制 20 字以内" },
          "content": { "type": "string", "maxLength": 1000, "description": "正文限制 1000 字以内" },
          "image_path": { "type": "string", "description": "本地图片绝对路径。确保图片已通过其它工具微调 MD5。" }
        },
        "required": ["title", "content", "image_path"]
      }
    }
  }
}
